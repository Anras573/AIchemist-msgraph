OPENAI_API_KEY=your-api-key

# Microsoft Graph credentials (required for calendar tools)
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Add a redirect URI: http://localhost (under Mobile and desktop applications)
# Grant it: Calendars.Read (delegated permission)
# Users will be prompted to log in via browser on first use
MSGRAPH_TENANT_ID=your-tenant-id
MSGRAPH_APP_ID=your-app-id
MSGRAPH_REDIRECT_URI=http://localhost:3000/
# Optional: defaults to Calendars.Read if not set
# MSGRAPH_SCOPE=Calendars.ReadWrite
